# MongoDB (cache + metrics + API key lookup)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB=llm_gateway

# Upstash Redis (rate limiting only) — free tier at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Model API key (Google Gemini — get one free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
